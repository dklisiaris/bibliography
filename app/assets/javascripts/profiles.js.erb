$('.profiles.show').ready(function() {
  function handleUploadSuccess(file, response) {
    if (window.hideModal) {
      window.hideModal(document.getElementById('avatarModal'));
      window.hideModal(document.getElementById('coverModal'));
    }

    var $cover = $('.cover').first();
    if (response.cover && response.cover.url && $cover.attr("src") !== response.cover.url) {
      $cover.attr("src", response.cover.url);
    }

    var $avatar = $('#profileAvatar');
    if (response.avatar && response.avatar.url && $avatar.length && $avatar.attr("src") !== response.avatar.url) {
      $avatar.attr("src", response.avatar.url);
      $('#topHeaderAvatar').attr("src", response.avatar.url);
    }

    this.removeFile(file);
  }

  var dropzoneOptions = {
    paramName: "file",
    maxFilesize: 2,
    maxFiles: 1,
    init: function() {
      this.on("success", handleUploadSuccess);
    }
  };

  Dropzone.options.avatarDropzone = dropzoneOptions;
  Dropzone.options.coverDropzone = dropzoneOptions;
});
