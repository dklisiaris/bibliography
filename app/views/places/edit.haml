- pages = {fa('home') => root_url, t('publishers.label') => publishers_path, @placeable.name => @placeable, t('places.edit', default: 'Edit place') => nil}

= content_header(breadcrumbs: pages)

.row.index-layout
  .col-lg-10.col-xl-9
    %section.index-panel.resource-form
      %header.index-panel__header
        %h1.index-panel__title= detone(t('places.edit', default: 'Editing place'))

      .index-panel__content
        = render 'publishers/publisher'

        = render 'form'

        .resource-form__footer-links
          = link_to t('back'), @placeable
