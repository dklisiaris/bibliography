= form_for [@placeable, @place], html: {role: 'form'} do |f|
  - if @place.errors.any?
    .alert.alert-danger
      %h2.h6
        = pluralize(@place.errors.count, 'error')
        prohibited this place from being saved:
      %ul.mb-0
        - @place.errors.full_messages.each do |message|
          %li= message

  .row
    .col-md-6.mb-3
      = f.label :name, class: 'form-label'
      = f.text_field :name, class: 'form-control'
    .col-md-6.mb-3
      = f.label :role, class: 'form-label'
      = f.text_field :role, class: 'form-control'
    .col-12.mb-3
      = f.label :address, class: 'form-label'
      = f.text_field :address, class: 'form-control'
    .col-md-6.mb-3
      = f.label :telephone, class: 'form-label'
      = f.text_field :telephone, class: 'form-control'
    .col-md-6.mb-3
      = f.label :fax, class: 'form-label'
      = f.text_field :fax, class: 'form-control'
    .col-md-6.mb-3
      = f.label :email, class: 'form-label'
      = f.text_field :email, class: 'form-control'
    .col-md-6.mb-3
      = f.label :website, class: 'form-label'
      = f.text_field :website, class: 'form-control'
    .col-md-6.mb-3
      = f.label :latitude, class: 'form-label'
      = f.text_field :latitude, class: 'form-control'
    .col-md-6.mb-3
      = f.label :longitude, class: 'form-label'
      = f.text_field :longitude, class: 'form-control'

  .resource-form__actions
    = f.submit t('save'), class: 'btn btn-primary'
