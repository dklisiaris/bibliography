= render layout: "pages/page_shell", locals: {title: detone(t("welcome")), col_class: "col-lg-10"} do
  .static-page__wizard
    #progress-wizard
      .progress.mb-3
        #progress-bar-wizard.progress-bar.bg-danger{role: "progressbar", style: "width: 0", "aria-valuenow": 0, "aria-valuemin": 0, "aria-valuemax": 100}

      %input{name: "email", type: "hidden", value: current_user.email}
      %input{name: "token", type: "hidden", value: current_user.token}

      #progress-first.step
        %p.text-muted.mb-3= t("choose_categories")
        .row.g-2
          - @featured_categories.each do |category|
            - selected_klass = current_user.likes?(category) ? "selected" : ""
            .col-6.col-sm-3
              %input{type: "checkbox", id: "category-#{category.id}", style: "display: none;"}
              %label.featured-category{class: selected_klass, for: "category-#{category.id}", onclick: "javascript:favouriteCategory(#{category.id})"}= category.name

      #progress-second.step
        %p.text-muted.mb-3= t("rate_books")
        #rateable-books-wrapper.loading-wrapper.loading

      #progress-third.step
        .loading-wrapper.loading

      .static-page__wizard-actions
        %button#back2.btn.btn-outline-secondary{type: "reset"}= t("back")
        %button#next2.btn.btn-primary{type: "submit"}= t("next")
