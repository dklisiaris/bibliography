- pages = {fa('home') => root_url, t('publishers.label') => publishers_path, @publisher.name => publisher_path(@publisher), t('publishers.editing') => nil}

= content_header(breadcrumbs: pages)

.row.index-layout
  .col-lg-10.col-xl-9
    %section.index-panel.resource-form
      %header.index-panel__header
        %h1.index-panel__title= detone t('publishers.editing')

      .index-panel__content
        = render 'form'

        .resource-form__footer-links
          = link_to t('show'), @publisher
          %span.mx-1 |
          = link_to t('back'), publishers_path
