= form_for @category, html: {role: 'form'} do |f|
  - if @category.errors.any?
    .alert.alert-danger
      %h2.h6
        = pluralize(@category.errors.count, 'error')
        prohibited this category from being saved:
      %ul.mb-0
        - @category.errors.full_messages.each do |message|
          %li= message

  .row
    .col-md-6.mb-3
      = f.label :name, t('name'), class: 'form-label'
      = f.text_field :name, class: 'form-control'
    .col-md-6.mb-3
      = f.label :ddc, class: 'form-label'
      = f.text_field :ddc, class: 'form-control'
    .col-md-6.mb-3
      = f.label :slug, class: 'form-label'
      = f.text_field :slug, class: 'form-control'
    .col-md-6.mb-3
      = f.label :biblionet_id, class: 'form-label'
      = f.number_field :biblionet_id, class: 'form-control'

  .mb-3
    .form-check
      = f.check_box :featured, class: 'form-check-input'
      = f.label :featured, class: 'form-check-label'

  = f.hidden_field :parent_id, value: @category.parent_id

  .resource-form__actions
    = f.submit t('save'), class: 'btn btn-primary'
