- pages = {fa('home') => root_url, t('categories.label') => categories_url, @category.name => category_path(@category), t('categories.editing') => nil}

= content_header(breadcrumbs: pages)

.row.index-layout
  .col-lg-10.col-xl-9
    %section.index-panel.resource-form
      %header.index-panel__header
        %h1.index-panel__title= detone t('categories.editing')

      .index-panel__content
        = render 'form'

        .resource-form__footer-links
          = link_to t('show'), @category
          %span.mx-1 |
          = link_to t('back'), categories_path
