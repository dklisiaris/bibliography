<% tags = { title: @category.name } %>
<% set_meta_tags tags.merge({og: tags}).merge(twitter: tags) %>

<%
if @category.parent_id.nil?
  pages = {fa('home') => root_url, t('categories.label') => categories_url, @category.name => nil}
else
  pages = {fa('home') => root_url, t('categories.label') => categories_url, @category.parent.name => @category.parent, @category.name => nil}
end
%>

<%= content_header( content: render(partial: 'shared/search_form',
    locals: {action: categories_path, placeholder: t('categories.search')}), breadcrumbs: pages) %>

<div class="row">
  <div class="col-sm-8">
      <div class="block full">
        <div class="block-title">
        <div class="block-options pull-right">
          <% if user_signed_in? %>
          <% category_favourited = current_user.likes?(@category) %>
          <%= button_tag fa(category_favourited ? 'star' : 'star-o'),
            type: "button",
            class: "btn btn-effect-ripple #{category_favourited ? 'btn-success' : 'btn-primary'} btn-favourite-category-#{@category.id}",
            data: {
              controller: "favourite",
              action: "click->favourite#toggle",
              toggle: "tooltip",
              original_title: category_favourited ? t('categories.favoured') : t('categories.add_to_favourites'),
              favourite_url_value: favourite_category_path(@category),
              favourite_record_id_value: @category.id,
              favourite_kind_value: "category",
              favourite_inactive_class_value: "btn-primary",
              favourite_add_label_value: t('categories.add_to_favourites'),
              favourite_favoured_label_value: t('categories.favoured')
            } %>
          <% else %>
          <%= button_tag fa('star-o'),
            type: "button",
            onclick: "javascript:favouriteCategory(#{@category.id})",
            class: "btn btn-effect-ripple btn-primary btn-favourite-category-#{@category.id}",
            data: { "toggle" => "tooltip", "original-title" => t('categories.add_to_favourites') } %>
          <% end %>
        </div>
          <h1><%= detone @category.name %></h1>
        </div>

        <div class="row">
          <%= render "books/widgets/pagination" %>
          <hr>
          <div class="col-xs-12">
            <%= render :partial =>  "books/book", :collection => @books, :as => :book %>
          </div>
          <%= render "books/widgets/pagination" %>
        </div>

      </div>
  </div>

  <div class="col-sm-4">
    <div class="block">
      <div class="block-title">
        <div class="block-options pull-right">
          <% if policy(@category).update? %>
          <%= nav_btn_link_to( name: fa('plus'), url: new_category_path(:parent_id => @category.id), tooltip: t('categories.new_subcategory')) %>
          <%= nav_btn_link_to( name: fa('pencil'), url: edit_category_path(@category), tooltip: t('categories.edit'), style: 'success') %>
          <% end %>
          <%= link_to fa('times'), @category, class: "btn btn-effect-ripple btn-danger",
            method: :delete, data: { confirm: t('u_sure'), "toggle" => "tooltip", "original-title" => t('categories.delete') } if policy(@category).destroy? %>
        </div>
        <h2><%= detone t('categories.label') %></h2>
      </div>
      <div class="list-group">
        <%= link_to fa('arrow-left'), @category.parent_id.nil? ? categories_path : @category.parent,
              class: 'list-group-item', id: "@category_#{@category.id}"  %>
        <%= render @children %>
      </div>
    </div>
  </div>
</div>

<%= link_to t('back'), categories_path, class: "label label-default" %>
