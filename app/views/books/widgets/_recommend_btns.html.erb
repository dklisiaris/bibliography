<% if user_signed_in? %>
<div data-controller="recommendation"
     data-recommendation-book-id-value="<%= book.id %>"
     data-recommendation-recommend-label-value="<%= t('books.recommend') %>"
     data-recommendation-not-recommend-label-value="<%= t('books.not_recommend') %>"
     data-recommendation-remove-recommendation-label-value="<%= t('books.remove_recommendation') %>">
<% end %>

<% if defined? show_progressbar.present? and show_progressbar %>
  <% total_votes = book.liked_by_count_cache + book.disliked_by_count_cache %>
  <% recommend_pct = total_votes.positive? ? (book.liked_by_count_cache.to_f / total_votes * 100) : 0 %>
  <div class="progress progress-mini">
    <div class="progress-bar bg-success recommendations-bar-<%= book.id %>"
         role="progressbar"
         aria-valuenow="<%= book.liked_by_count_cache %>"
         aria-valuemin="0"
         aria-valuemax="<%= total_votes %>"
         style="width: <%= recommend_pct %>%"></div>
  </div>
<% end %>

<% if user_signed_in? %>
<%= button_tag type: "button",
  data: {
    bs_toggle: "tooltip",
    bs_placement: "top",
    action: "click->recommendation#like"
  },
  title: (@liked_book_ids.include?(book.id)) ? t('books.remove_recommendation') : t('books.recommend'),
  class: "btn btn-xs btn-like btn-like-#{book.id} #{(@liked_book_ids.include?(book.id)) ? 'btn-success' : 'btn-outline-secondary'}" do %>
  <i class="fa fa-thumbs-up"></i><strong><span><%= " #{book.liked_by_count_cache}" %></span></strong>
<% end %>

<%= button_tag type: "button",
  data: {
    bs_toggle: "tooltip",
    bs_placement: "top",
    action: "click->recommendation#dislike"
  },
  title: (@disliked_book_ids.include?(book.id)) ? t('books.remove_recommendation') : t('books.not_recommend'),
  class: "btn btn-xs btn-dislike btn-dislike-#{book.id} #{(@disliked_book_ids.include?(book.id)) ? 'btn-danger' : 'btn-outline-secondary'}" do %>
  <i class="fa fa-thumbs-down"></i><strong><span><%= " #{book.disliked_by_count_cache}" %></span></strong>
<% end %>
</div>
<% else %>

<%= link_to new_user_session_path,
  data: { bs_toggle: "tooltip", bs_placement: "top" },
  title: t('books.recommend'),
  class: "btn btn-xs btn-like btn-outline-secondary" do %>
    <i class="fa fa-thumbs-up"></i><strong><span><%= " #{book.liked_by_count_cache}" %></span></strong>
<% end %>

<%= link_to new_user_session_path,
  data: { bs_toggle: "tooltip", bs_placement: "top" },
  title: t('books.not_recommend'),
  class: "btn btn-xs btn-dislike btn-outline-secondary" do %>
    <i class="fa fa-thumbs-down"></i><strong><span><%= " #{book.disliked_by_count_cache}" %></span></strong>
<% end %>

<% end %>
