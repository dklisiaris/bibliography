<% if @books.present? %>
<%= turbo_stream.prepend "awarded-books-grid" do %>
  <% @books.each do |book| %>
    <%= render partial: "books/awarded_book", locals: { book: book, prize_id: params[:prize_id] } %>
  <% end %>
<% end %>

<%= turbo_stream.update "load-more-awarded-books" do %>
  <%= turbo_load_more_link(@books, class: "book-grid__more", data: { turbo_stream: true }) %>
<% end %>
<% end %>

<% if @prizes.present? %>
<%= turbo_stream.append "load-more-awards-container" do %>
  <%= render partial: "prizes/prize_nav_item", collection: @prizes, as: :prize, locals: { selected_prize_id: params[:prize_id] } %>
<% end %>

<%= turbo_stream.update "load-more-awards-btn" do %>
  <%= turbo_load_more_link(@prizes, class: "book-grid__more", data: { turbo_stream: true }) %>
<% end %>
<% end %>
