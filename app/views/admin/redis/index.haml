- pages = {fa('home') => root_url, 'Admin' => '#', 'Redis Browser' => nil}

= content_header(title: 'Redis Browser', breadcrumbs: pages)

.row.index-layout
  .col-12
    %section.index-panel.admin-redis
      %header.index-panel__header
        %h1.index-panel__title
          = fa('database')
          Redis Keys
        .index-panel__actions
          = link_to admin_redis_stats_path, class: 'btn btn-sm btn-info' do
            = fa('bar-chart')
            Stats

      .index-panel__content
        = form_tag admin_redis_path, method: :get, class: 'admin-redis__filters' do
          .row.g-2.align-items-end
            .col-sm-auto
              %label.form-label{for: 'namespace'} Namespace
              = text_field_tag :namespace, @namespace, class: 'form-control', placeholder: 'e.g. bibliography', id: 'namespace'
            .col-sm-auto
              %label.form-label{for: 'pattern'} Pattern
              = text_field_tag :pattern, @pattern, class: 'form-control', placeholder: '*', id: 'pattern'
            .col-sm-auto
              .admin-redis__filter-actions
                = submit_tag 'Search', class: 'btn btn-primary'
                = link_to 'Clear', admin_redis_path, class: 'btn btn-outline-secondary'

        .alert.alert-info.admin-redis__summary.d-flex.flex-wrap.justify-content-between.align-items-center.gap-2
          %div
            %strong Total keys found:
            = @total_keys
          - if @total_keys > @per_page
            %span.text-muted
              Showing #{(@page - 1) * @per_page + 1} - #{[@page * @per_page, @total_keys].min} of #{@total_keys}

        - if @keys_info.any?
          .table-responsive
            %table.table.table-striped.table-hover.admin-redis__table
              %thead
                %tr
                  %th Key
                  %th Type
                  %th Size/Count
                  %th TTL
                  %th Actions
              %tbody
                - @keys_info.each do |key_info|
                  %tr
                    %td
                      %code= key_info[:key]
                    %td
                      %span.badge{class: type_badge_class(key_info[:type])}
                        = key_info[:type].upcase
                    %td= key_info[:size]
                    %td
                      - if key_info[:ttl].is_a?(Integer)
                        = distance_of_time_in_words(Time.now, Time.now + key_info[:ttl])
                      - else
                        %span.text-muted= key_info[:ttl]
                    %td
                      .admin-redis__row-actions
                        = link_to admin_redis_key_path(key_info[:key]), class: 'btn btn-sm btn-primary' do
                          = fa('eye')
                          View
                        = link_to admin_redis_delete_path(key_info[:key]), method: :delete, class: 'btn btn-sm btn-danger', data: {confirm: "Are you sure you want to delete '#{key_info[:key]}'?"} do
                          = fa('trash')
                          Delete

          - if @total_keys > @per_page
            %nav.pagination-nav{aria: {label: 'Pagination'}}
              = paginate_keys(@page, @total_keys, @per_page)
        - else
          .alert.alert-warning.mb-0
            No keys found matching pattern:
            %code= @namespace.present? ? "#{@namespace}:#{@pattern}" : @pattern
