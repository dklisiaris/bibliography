<%# Rails flash messages — shown as top-right toasts via Stimulus %>
<% flash.each do |name, msg| %>
  <% next unless msg.is_a?(String) %>
  <%= tag.div hidden: true,
        data: {
          controller: "flash",
          flash_message_value: msg,
          flash_type_value: (name.to_s == "notice" ? "success" : "error")
        } %>
<% end %>
