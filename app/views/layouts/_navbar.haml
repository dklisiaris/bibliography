%header.app-shell__navbar{role: "banner"}
  .app-shell__navbar-inner
    .app-shell__navbar-start
      %button.app-shell__sidebar-toggle.d-lg-none.btn.btn-link{type: "button", data: {bs_toggle: "offcanvas", bs_target: "#appSidebarOffcanvas"}, aria: {controls: "appSidebarOffcanvas", label: t("side_menu.navigation", default: "Navigation")}}
        %i.fa.fa-bars{aria: {hidden: true}}

      %button.app-shell__sidebar-toggle.d-none.d-lg-inline-flex.btn.btn-link{type: "button", data: {action: "click->app-shell#toggleDesktopSidebar"}, aria: {label: t("side_menu.toggle_sidebar", default: "Toggle sidebar")}}
        %i.fa.fa-bars.fa-fw.app-shell__sidebar-toggle-full{aria: {hidden: true}}
        %i.fa.fa-ellipsis-v.fa-fw.app-shell__sidebar-toggle-mini{aria: {hidden: true}}

      %ul.nav.app-shell__nav
        = top_nav_li(UnicodeUtils.upcase(detone(t("home"))), root_path, nil, "hidden-xs")
        = top_nav_li(UnicodeUtils.upcase(detone(t("collections"))), shelves_path, nil, "hidden-xs")
        = top_nav_li(UnicodeUtils.upcase(detone(t("my_books"))), my_books_path, nil, "hidden-xs")

    = link_to image_tag("logos/logo120.png"), root_path, class: "app-shell__navbar-brand d-lg-none"

    .app-shell__navbar-end
      %ul.nav.app-shell__nav
        - if user_signed_in?
          = top_nav_li(current_user.screen_name, public_profile_path, nil, "hidden-xs")
          = top_nav_li("", public_profile_path, "fa fa-user-circle-o", "visible-xs")
          = render "layouts/user_menu"
        - else
          = top_nav_li(UnicodeUtils.upcase(t("login")), new_user_session_path, nil, "hidden-xs")
          = top_nav_li(UnicodeUtils.upcase(t("signup")), new_user_registration_path, nil, "hidden-xs")
          = top_nav_li("", new_user_session_path, "fa fa-sign-in", "visible-xs")
          = top_nav_li("", new_user_registration_path, "fa fa-user-plus", "visible-xs")
