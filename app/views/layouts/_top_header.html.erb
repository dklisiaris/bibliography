          <!-- BEGIN HEADER -->
          <header class="navbar navbar-default navbar-fixed-top">
            <ul class="nav navbar-nav-custom">
              <li>
                <a href="javascript:void(0)" onclick="App.sidebar('toggle-sidebar');">
                <i class="fa fa-ellipsis-v fa-fw animation-fadeInRight" id="sidebar-toggle-mini"></i>
                <i class="fa fa-bars fa-fw animation-fadeInRight" id="sidebar-toggle-full"></i>
                </a>
              </li>
              <%= top_nav_li(UnicodeUtils.upcase(detone(t('home'))), root_path, nil, 'hidden-xs') %>
              <%= top_nav_li(UnicodeUtils.upcase(detone(t('collections'))), shelves_path, nil, 'hidden-xs') %>
              <%= top_nav_li(UnicodeUtils.upcase(detone(t('my_books'))), my_books_path, nil, 'hidden-xs') %>

            </ul>

            <%= link_to image_tag('logos/logo120.png'), root_path, class: 'navbar-brand visible-xs' %>

            <ul class="nav navbar-nav-custom pull-right">
              <% if user_signed_in? %>
              <%= top_nav_li(current_user.screen_name, public_profile_path, nil, 'hidden-xs') %>
              <%= top_nav_li('', public_profile_path, 'fa fa-user-circle-o', 'visible-xs') %>
              <%= render 'layouts/user_menu' %>
              <% else %>
                <%= top_nav_li(UnicodeUtils.upcase(t('login')), new_user_session_path, nil, 'hidden-xs') %>
                <%= top_nav_li(UnicodeUtils.upcase(t('signup')), new_user_registration_path, nil, 'hidden-xs') %>
                <%= top_nav_li('', new_user_session_path, 'fa fa-sign-in', 'visible-xs') %>
                <%= top_nav_li('', new_user_registration_path, 'fa fa-user-plus', 'visible-xs') %>
              <% end %>
            </ul>
          </header>
          <!-- END HEADER -->
