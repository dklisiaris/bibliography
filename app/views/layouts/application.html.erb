<!DOCTYPE html>
<html lang='el'>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%= display_meta_tags fb: {app_id: Rails.application.secrets.FACEBOOK_APP_ID} %>
    <%= favicon_link_tag 'icons/favicon-16x16.png', type: 'image/png', sizes: '16x16' %>
    <%= favicon_link_tag 'icons/favicon-32x32.png', type: 'image/png', sizes: '32x32' %>
    <%= favicon_link_tag 'icons/favicon-96x96.png', type: 'image/png', sizes: '96x96' %>
    <%= favicon_link_tag 'icons/favicon-128x128.png', type: 'image/png', sizes: '128x128' %>
    <%= favicon_link_tag 'icons/favicon-196x196.png', type: 'image/png', sizes: '196x196' %>

    <%= favicon_link_tag 'icons/apple-touch-icon-57x57.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '57x57' %>
    <%= favicon_link_tag 'icons/apple-touch-icon-72x72.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '72x72' %>
    <%= favicon_link_tag 'icons/apple-touch-icon-76x76.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '76x76' %>
    <%= favicon_link_tag 'icons/apple-touch-icon-114x114.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '114x114' %>
    <%= favicon_link_tag 'icons/apple-touch-icon-120x120.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '120x120' %>
    <%= favicon_link_tag 'icons/apple-touch-icon-144x144.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '144x144' %>
    <%= favicon_link_tag 'icons/apple-touch-icon-152x152.png', rel: 'apple-touch-icon', type: 'image/png', sizes: '152x152' %>

    <meta name="application-name" content="BibliographyGR"/>
    <meta name="msapplication-TileColor" content="#de4b39" />
    <meta name="msapplication-TileImage" content="icons/mstile-144x144.png" />
    <meta name="msapplication-square70x70logo" content="icons/mstile-70x70.png" />
    <meta name="msapplication-square150x150logo" content="icons/mstile-150x150.png" />
    <meta name="msapplication-wide310x150logo" content="icons/mstile-310x150.png" />
    <meta name="msapplication-square310x310logo" content="icons/mstile-310x310.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@200;300;400;500;600;700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_include_tag 'application' %>
    <%= stylesheet_link_tag 'hotwire', media: 'all', data: { turbo_track: 'reload' } %>

    <script type='application/ld+json'>
    {
      "@context":"http:\/\/schema.org",
      "@type":"WebSite",
      "@id":"#website",
      "url":"https:\/\/www.bibliography.gr\/",
      "name":"Bibliography.gr",
      "alternateName":"Elliniki vivliografia",
      "potentialAction":{
        "@type":"SearchAction",
        "target":"https:\/\/www.bibliography.gr\/search\/?q={search_term}",
        "query-input":"required name=search_term"
      }
    }
    </script>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <meta name="turbo-cache-control" content="no-cache">

    <script> (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){ (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o), m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m) })(window,document,'script','https://www.google-analytics.com/analytics.js','ga'); ga('create', 'UA-61773702-1', 'auto'); ga('send', 'pageview'); </script>
    <%= javascript_include_tag 'hotwire', defer: true, type: 'module', data: { turbo_track: 'reload' } %>
  </head>

  <body class="<%= controller_name %> <%= action_name %>">
    <div class="app-shell" data-controller="app-shell">
      <aside id="sidebar" class="app-shell__sidebar d-none d-lg-flex" role="navigation" aria-label="Main navigation">
        <%= render 'layouts/sidebar_nav' %>
      </aside>

      <div class="offcanvas offcanvas-start app-shell__offcanvas d-lg-none" tabindex="-1" id="appSidebarOffcanvas" aria-labelledby="appSidebarOffcanvasLabel">
        <div class="offcanvas-header">
          <h5 class="offcanvas-title" id="appSidebarOffcanvasLabel"><%= t('side_menu.navigation', default: 'Navigation') %></h5>
          <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="<%= t('close', default: 'Close') %>"></button>
        </div>
        <div class="offcanvas-body p-0">
          <%= render 'layouts/sidebar_nav', mobile: true %>
        </div>
      </div>

      <div class="app-shell__stage">
        <%= render 'layouts/navbar' %>

        <div id="fb-root"></div>

        <div id="page-content" class="app-shell__main">
          <%= yield :content_header %>
          <%= render 'layouts/messages' %>
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
