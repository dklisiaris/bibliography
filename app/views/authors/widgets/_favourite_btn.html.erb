<% if user_signed_in? %>
<%= button_tag fa(liked ? 'star' : 'star-o'),
  type: "button",
  class: "btn btn-xs #{liked ? 'btn-success' : 'btn-outline-secondary'} btn-favourite-author-#{author.id}",
  title: liked ? t('authors.favoured') : t('authors.add_to_favourites'),
  data: {
    controller: "favourite",
    action: "click->favourite#toggle",
    bs_toggle: "tooltip",
    favourite_url_value: favourite_author_path(author),
    favourite_record_id_value: author.id,
    favourite_kind_value: "author",
    favourite_inactive_class_value: "btn-outline-secondary",
    favourite_add_label_value: t('authors.add_to_favourites'),
    favourite_favoured_label_value: t('authors.favoured')
  }
%>
<% else %>
<%= link_to fa('star-o'), new_user_session_path,
  class: "btn btn-xs btn-outline-secondary btn-favourite-author-#{author.id}",
  title: t('authors.add_to_favourites'),
  data: { bs_toggle: "tooltip" }
%>
<% end %>
