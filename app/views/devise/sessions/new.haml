.auth-page
  .auth-page__brand
    %h1.auth-page__title
      %i.fa.fa-book{aria: {hidden: true}}
      %strong= t("welcome")

  %section.index-panel.auth-card
    %header.index-panel__header
      %h2.index-panel__title= detone t("please_login")
      .index-panel__actions.auth-card__actions
        - if devise_mapping.recoverable?
          = link_to new_password_path(resource_name), class: "btn btn-sm btn-outline-secondary btn-icon", title: t("forgot_password"), data: {bs_toggle: "tooltip"} do
            %i.fa.fa-exclamation-circle{aria: {hidden: true}}
        - if devise_mapping.registerable?
          = link_to new_registration_path(resource_name), class: "btn btn-sm btn-primary btn-icon", title: t("create_account"), data: {bs_toggle: "tooltip"} do
            %i.fa.fa-plus{aria: {hidden: true}}

    .index-panel__content
      = form_for(resource, as: resource_name, url: session_path(resource_name), html: {role: "form", data: {turbo: false}}) do |f|
        = devise_error_messages!

        .mb-3
          = f.label :email, class: "form-label"
          = f.email_field :email, autofocus: true, class: "form-control", placeholder: t("enter_email")

        .mb-3
          = f.label :password, t("password"), class: "form-label"
          = f.password_field :password, class: "form-control", placeholder: t("enter_password")

        .auth-card__remember
          - if devise_mapping.rememberable?
            .form-check
              = f.check_box :remember_me, class: "form-check-input"
              = f.label :remember_me, t("remember_me"), class: "form-check-label"
          = button_tag type: "submit", class: "btn btn-primary" do
            %i.fa.fa-check{aria: {hidden: true}}
            %span= t("login")

      %hr.auth-card__divider/
      .auth-card__oauth
        = render "devise/shared/oauth_buttons"

  = render "devise/shared/auth_footer"
