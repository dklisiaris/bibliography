= link_to user_facebook_omniauth_authorize_path, class: "btn btn-fb w-100", data: {turbo: false} do
  %i.fa.fa-facebook{aria: {hidden: true}}
  %span= " Login with Facebook"
= link_to user_google_oauth2_omniauth_authorize_path, class: "btn btn-gl w-100", data: {turbo: false} do
  %i.fa.fa-google{aria: {hidden: true}}
  %span= " Login with Google"
