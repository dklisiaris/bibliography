{
  "name": "bibliography",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo": "^8.0.12",
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "dropzone": "4.3.0",
    "esbuild": "^0.25.0",
    "font-awesome": "^4.7.0",
    "masonry-layout": "4.2.2",
    "sass": "1.77.8",
    "trix": "^2.1.19"
  },
  "scripts": {
    "build": "npm run build:js && npm run build:css",
    "build:js": "esbuild app/javascript/hotwire.js --bundle --sourcemap --format=esm --outfile=app/assets/builds/hotwire.js --public-path=/assets",
    "build:css:fonts": "mkdir -p app/assets/builds/fa-fonts && cp node_modules/font-awesome/fonts/* app/assets/builds/fa-fonts/",
    "build:css": "npm run build:css:fonts && sass ./app/assets/styles/hotwire.scss:./app/assets/builds/hotwire.css --style=compressed --no-source-map --load-path=node_modules --quiet-deps",
    "build:css:watch": "npm run build:css:fonts && sass ./app/assets/styles/hotwire.scss:./app/assets/builds/hotwire.css --no-source-map --load-path=node_modules --quiet-deps --watch",
    "verify:build": "test -f app/assets/builds/hotwire.js && test -f app/assets/builds/hotwire.css"
  }
}
